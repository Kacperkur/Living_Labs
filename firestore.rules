rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Labs are read-only from the client — all writes go through the Admin SDK (API routes)
    match /labs/{labId} {
      allow read: if true;
      allow write: if false;
    }

    // Users can read and write only their own profile document
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
