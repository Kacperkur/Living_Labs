rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Anyone can read all files (lab covers, SDG icons, building photos, profile pictures)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Authenticated users can upload/replace only their own profile picture
    match /profile-pictures/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // All other writes go through the Admin SDK (API routes)
    match /{allPaths=**} {
      allow write: if false;
    }
  }
}
