# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ignore firebase admin service accounts and local env
livinglabs-1a831-firebase-adminsdk-*.json
*.firebase-adminsdk-*.json
*-firebase-adminsdk-*.json
.env
.env.local
.env.*.local

# secrets folder (keep service account JSONs out of the repo)
living_labs_secrets/
living_labs_secrets/*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase service account and project files
livinglabs-1a831
