# Copy this file to `.env.local` (which is ignored) and fill values for local development.
# You can either point to the JSON file in your secrets folder or provide the file's contents as base64.

# 1) Path to the service account JSON (relative to repo root or absolute):
# LIVINGLABS_ADMINSDK_PATH=./living_labs_secrets/livinglabs-1a831-firebase-adminsdk-fbsvc-0fafb06513.json

# 2) Or, encode the JSON and store as base64 in the env (useful for CI/CD):
# LIVINGLABS_ADMINSDK_BASE64=eyJ0eXAiOiJKV1QiLCJhbGciOiJI... (base64 of the whole JSON file)

# Firebase Storage bucket (without gs:// prefix)
FIREBASE_STORAGE_BUCKET=livinglabs-1a831.firebasestorage.app

# Note: On many platforms you can also set `GOOGLE_APPLICATION_CREDENTIALS` to a path
# but this repo's code prefers the two variables above for explicit control.
